# Normalize line endings: LF in repo, native on checkout
* text=auto

# Files that must always be LF (executed inside Linux containers)
*.sh text eol=lf
Dockerfile text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.sql text eol=lf
Makefile text eol=lf

# Binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
